# Copy this file to .env and fill in all values marked with <...>.
# .env is intentionally git-ignored — never commit it.

# ---- PostgreSQL ----
MATCHWIZ_DB_NAME=matchwiz
MATCHWIZ_DB_USER=matchwiz
MATCHWIZ_DB_PASSWORD=<strong-password>

# ---- Backend: admin bootstrap account ----
# Created once at first startup (idempotent). Change the password immediately after.
MATCHWIZ_ADMIN_USERNAME=admin
MATCHWIZ_ADMIN_PASSWORD=<strong-admin-password>

# ---- Backend: CORS ----
# With Lighttpd reverse proxy (recommended): set to your Pi's hostname/IP.
# Without reverse proxy (direct port access): set to http://<host>:<MATCHWIZ_FRONTEND_PORT>
MATCHWIZ_CORS_ORIGINS=http://localhost

# ---- Frontend port on the host (Lighttpd reverse proxy target) ----
# The app is only bound to 127.0.0.1, so this port is not reachable from outside.
# Lighttpd proxies /matchwiz/ → 127.0.0.1:<this port>.
MATCHWIZ_FRONTEND_PORT=8080

# ---- JWT keys ----
# Do NOT set these here — they are mounted as files from the secrets/ directory.
# See docker-compose.yml prerequisites.
